    {
      "parameters": {
        "jsCode": "const webhook = $('On form submission').first().json;\nconst rawOutput = $('Lead Scoring').first().json.output;\nconst creditMemo = $('Credit Memo').first().json.output;\n\nlet aiOutput = {};\ntry {\n  const cleaned = rawOutput\n    .replace(/```json/g, '')\n    .replace(/```/g, '')\n    .replace(/\\n/g, ' ')\n    .trim();\n  aiOutput = JSON.parse(cleaned);\n} catch(e) {\n  aiOutput = {\n    score: 'N/A',\n    recommendation: 'N/A',\n    reason: 'N/A',\n    risk_level: 'N/A'\n  };\n}\n\nlet finalDecision = 'N/A';\nif (creditMemo.includes('APPROVE') && !creditMemo.includes('MORE_INFO') && !creditMemo.includes('REJECT')) {\n  finalDecision = 'APPROVED';\n} else if (creditMemo.includes('REJECT')) {\n  finalDecision = 'REJECTED';\n} else if (creditMemo.includes('MORE_INFO')) {\n  finalDecision = 'PENDING - DOCS REQUIRED';\n}\n\nlet requiredDocs = 'N/A';\nif (finalDecision === 'PENDING - DOCS REQUIRED') {\n  const docsMatch = creditMemo.match(/Required Documents:([\\s\\S]*?)(?:Follow up:|Credit Officer:|$)/);\n  if (docsMatch) {\n    requiredDocs = docsMatch[1].trim();\n  }\n}\n\nconst currencyRaw = webhook['Currency'];\nconst currency = Array.isArray(currencyRaw)\n  ? currencyRaw[0]\n  : (currencyRaw || '');\n\nconst formattedDate = new Date().toLocaleDateString('en-GB', {\n  day: '2-digit',\n  month: '2-digit',\n  year: 'numeric'\n});\n\nreturn [{\n  json: {\n    Timestamp: formattedDate,\n    Applicant_name: webhook['Applicant Name'] || 'N/A',\n    Company_name: webhook['Company Name'] || 'N/A',\n    Business_type: webhook['Business Type'] || 'N/A',\n    Country: webhook['Country'] || 'N/A',\n    Currency: currency,\n    Loan_amount: currency + ' ' + (webhook['Loan Amount Requested'] || 'N/A'),\n    Monthly_revenue: currency + ' ' + (webhook['Monthly Revenue'] || 'N/A'),\n    Lead_score: aiOutput.score || 'N/A',\n    Risk_level: aiOutput.risk_level || 'N/A',\n    Recommendation: aiOutput.recommendation || 'N/A',\n    Final_Decision: finalDecision,\n    Required_docs: requiredDocs,\n    Email: webhook['Email'] || 'N/A'\n  }\n}];"
      },
